# Database (Supabase PostgreSQL)
DATABASE_URL=postgresql://postgres:password@db.example.supabase.co:6543/postgres

# Supabase (for additional Supabase features)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# OAuth
OAUTH_SERVER_URL=https://your-oauth-server
VITE_APP_ID=your-app-id
JWT_SECRET=your-jwt-secret
OWNER_OPEN_ID=your-open-id

# Manus Forge (existing integrations)
BUILT_IN_FORGE_API_URL=https://your-forge-api
BUILT_IN_FORGE_API_KEY=your-forge-api-key

# Client-side env (prefixed with VITE_)
VITE_OAUTH_PORTAL_URL=https://your-oauth-portal
VITE_ANALYTICS_ENDPOINT=
VITE_ANALYTICS_WEBSITE_ID=

# Node
NODE_ENV=production
PORT=3000
