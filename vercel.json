{
  "version": 2,
  "buildCommand": "pnpm run build:vercel",
  "outputDirectory": "dist/public",
  "installCommand": "pnpm install",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/index.mjs" },
    { "source": "/(.*)", "destination": "/api/index.mjs" }
  ],
  "functions": {
    "api/index.mjs": {
      "memory": 512,
      "maxDuration": 30
    }
  }
}